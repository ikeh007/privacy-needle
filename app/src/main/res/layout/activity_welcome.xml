<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@drawable/bgbg"
    tools:context=".MainActivity">


    <!-- Heading Text for PrivacyNeedle -->

    <ImageView
        android:id="@+id/background_image"
        android:layout_width="match_parent"
        android:layout_height="360dp"
        android:layout_centerHorizontal="true"
        android:src="@drawable/privndeed"
        android:layout_marginTop="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />



    <TextView
        android:id="@+id/heading_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/background_image"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="24dp"
        android:layout_marginTop="70dp"
        android:text="Your Privacy Matters"
        android:textColor="#FFFFFF"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/subheading_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBottom="@id/heading_text"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="100dp"
        android:layout_marginBottom="-19dp"
        android:textSize="11sp"
        android:text= "Protecting, Investigating and Reporting - Data Privacy.  "
        android:textColor="#FFFF"
        android:textStyle="bold" />
    <TextView
        android:id="@+id/subhead_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBottom="@id/subheading_text"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="-12dp"
        android:textSize="8sp"
        android:text= " Your Personal Data Protection Resource Tool and Updates"
        android:textColor="#FFFF"
         />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/subheading_text" />

    <!-- Get Started Button -->
    <Button
        android:id="@+id/btnGetStarted"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="Get Started"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:background="@drawable/btn_rounded_yellow"
        android:layout_alignBottom="@id/subheading_text"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="-100dp" />

</RelativeLayout>